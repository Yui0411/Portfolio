# ============================================================
# Portfolio — environment variables
# Copy this file to `.env.local` (which is gitignored) and fill in
# the values from your Supabase project: Settings → API.
# ============================================================

# Public — safe to expose to the browser. Used by the public site + admin login.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser, never commit.
# Used for privileged server actions and the Lambda visit-tracker.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public visit-tracker endpoint, API Gateway in front of the Lambda
# (optional locally; tracking is skipped if unset).
NEXT_PUBLIC_TRACK_URL=https://your-api-id.execute-api.ap-southeast-2.amazonaws.com/track
